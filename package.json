  "node-red": {
    "version": ">=0.14.0",
    "nodes": {
      "ur_base": "nodes/ur_base.js",
      "ur_button": "nodes/ur_button.js",
      "ur_compare": "nodes/ur_compare.js",
      "ur_chart": "nodes/ur_chart.js",
      "ur_datalog": "nodes/ur_datalog.js",
      "ur_gauge": "nodes/ur_gauge.js",
      "ur_folder": "nodes/ur_folder.js",
      "ur_page": "nodes/ur_page.js",
      "ur_group": "nodes/ur_group.js",
      "ur_form": "nodes/ur_form.js",
      "ur_tab": "nodes/ur_tab.js",
      "ur_text": "nodes/ur_text.js",
      "ur_text_input": "nodes/ur_text_input.js",
      "ur_template": "nodes/ur_template.js",
      "ur_alarm": "nodes/ur_alarm.js",
      "ur_alarm_console": "nodes/ur_alarm_console.js",
      "ur_animation": "nodes/ur_animation.js",
